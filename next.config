/** @type {import('next').NextConfig} */
const nextConfig = {
  experimental: {
    turbo: {
      root: './glucoseverified-site'
    }
  },
  // Add this to fix the webpack cache warning
  webpack: (config, { isServer }) => {
    if (!isServer) {
      config.cache = false;
    }
    return config;
  },
}

module.exports = nextConfig